Step 1: Create a "deployment.yaml" file

apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx
  labels:
    app: nginx
spec:
  selector:
    matchLabels:
      app: nginx
  replicas: 1
  template:
    metadata:
      labels:
        app: nginx
    spec:
      containers:
        - name: nginx
          image: nginx:latest
          ports:
          - containerPort: 80

		  

Step 2: Apply the CRD file:

kubectl apply -f deployment.yaml



Step 3: Verification:

kubectl get deploy
kubectl get pods		  
